---
import Layout from "../layouts/Layout.astro";
---

<Layout title="L'Equip - Ara què?">
  <main class="pt-24 pb-20 max-w-7xl mx-auto px-6 bg-white">
    <div class="text-center mb-20 space-y-4">
      <div
        class="inline-block px-4 py-1.5 bg-[#A7D6E9] text-white rounded-full text-xs font-black tracking-widest uppercase"
      >
        QUI SOM?
      </div>
      <h1
        class="text-5xl md:text-7xl font-black tracking-tighter text-slate-900 leading-[1.1]"
      >
        L'equip darrere d'Ara què?
      </h1>
      <p class="text-slate-500 max-w-2xl mx-auto font-medium">
        Som alumnes de l'Institut Pla de l'Estany.
      </p>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12"
    >
      <div class="space-y-4 group">
        <div
          class="aspect-square bg-slate-50 rounded-[2.5rem] overflow-hidden border border-slate-100 transition-all group-hover:shadow-xl group-hover:shadow-blue-100"
        >
          <img
            src="https://api.dicebear.com/8.x/avataaars-neutral/svg?seed=Pau"
            alt="Pau España"
            class="w-full h-full object-cover grayscale transition-all group-hover:grayscale-0 duration-500"
          />
        </div>
        <div class="space-y-0.5">
          <h3 class="text-lg font-bold text-slate-950">Pau España</h3>
          <p class="text-xs font-bold text-blue-600 uppercase tracking-wider">
            PROJECT MANAGER
          </p>
          <p class="text-sm font-medium text-slate-500">
            Database Administrator
          </p>
        </div>
      </div>

      <div class="space-y-4 group">
        <div
          class="aspect-square bg-slate-50 rounded-[2.5rem] overflow-hidden border border-slate-100 transition-all group-hover:shadow-xl group-hover:shadow-emerald-100"
        >
          <img
            src="https://api.dicebear.com/8.x/avataaars-neutral/svg?seed=Sergi"
            alt="Sergi Pujol"
            class="w-full h-full object-cover grayscale transition-all group-hover:grayscale-0 duration-500"
          />
        </div>
        <div class="space-y-0.5">
          <h3 class="text-lg font-bold text-slate-950">Sergi Pujol</h3>
          <p
            class="text-xs font-bold text-emerald-600 uppercase tracking-wider"
          >
            DOCUMENTATION MANAGER
          </p>
          <p class="text-sm font-medium text-slate-500">Comercial</p>
        </div>
      </div>

      <div class="space-y-4 group">
        <div
          class="aspect-square bg-slate-50 rounded-[2.5rem] overflow-hidden border border-slate-100 transition-all group-hover:shadow-xl group-hover:shadow-rose-100"
        >
          <img
            src="https://api.dicebear.com/8.x/avataaars-neutral/svg?seed=Cristhian"
            alt="Cristhian Josue Macias"
            class="w-full h-full object-cover grayscale transition-all group-hover:grayscale-0 duration-500"
          />
        </div>
        <div class="space-y-0.5">
          <h3 class="text-lg font-bold text-slate-950">
            Cristhian Josue Macias
          </h3>
          <p class="text-xs font-bold text-rose-600 uppercase tracking-wider">
            PROGRAMMING MANAGER
          </p>
          <p class="text-sm font-medium text-slate-500">Fullstack Developer</p>
        </div>
      </div>

      <div class="space-y-4 group">
        <div
          class="aspect-square bg-slate-50 rounded-[2.5rem] overflow-hidden border border-slate-100 transition-all group-hover:shadow-xl group-hover:shadow-amber-100"
        >
          <img
            src="https://api.dicebear.com/8.x/avataaars-neutral/svg?seed=Alex"
            alt="Alexsander Acuña"
            class="w-full h-full object-cover grayscale transition-all group-hover:grayscale-0 duration-500"
          />
        </div>
        <div class="space-y-0.5">
          <h3 class="text-lg font-bold text-slate-950">Alexsander Acuña</h3>
          <p class="text-xs font-bold text-amber-600 uppercase tracking-wider">
            ART DIRECTOR
          </p>
          <p class="text-sm font-medium text-slate-500">UI/UX Designer</p>
        </div>
      </div>
    </div>
  </main>
</Layout>
