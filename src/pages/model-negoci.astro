---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Model de Negoci - Ara què?">
  <main class="pt-32 pb-20 bg-white">
    <section class="max-w-5xl mx-auto px-6 mb-16 text-center">
      <h1
        class="text-5xl font-black tracking-tighter text-slate-900 mb-4 italic"
      >
        Anàlisi Econòmica
      </h1>
      <div class="w-24 h-1.5 bg-[#F9C18A] mx-auto rounded-full mb-6 opacity-30">
      </div>
      <p class="text-slate-500 max-w-2xl mx-auto font-medium">
        Transparència en la valoració del desenvolupament actual i el full de
        ruta per a la implementació real a la <span
          class="text-[#A7D6E9] font-bold">Fundació Mas Casadevall</span
        >.
      </p>
    </section>

    <section class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-3 gap-8 items-start">
        <div class="lg:col-span-2 space-y-8">
          <div
            class="bg-white rounded-[2.5rem] shadow-2xl shadow-sky-100/50 border border-slate-100 overflow-hidden"
          >
            <div
              class="bg-[#A7D6E9] p-8 text-white flex justify-between items-center"
            >
              <div>
                <p
                  class="text-white/80 text-xs font-black uppercase tracking-widest mb-1"
                >
                  Fase 1
                </p>
                <h2 class="text-2xl font-bold italic">
                  Estat Actual del Projecte
                </h2>
              </div>
              <div class="text-right">
                <p class="text-[10px] text-white/60 uppercase font-bold">
                  Hores totals
                </p>
                <p class="text-3xl font-black">280h</p>
              </div>
            </div>

            <div class="p-8">
              <table class="w-full text-left">
                <thead>
                  <tr
                    class="text-[10px] uppercase text-slate-400 border-b border-slate-100"
                  >
                    <th class="pb-4 font-black tracking-widest">Concepte</th>
                    <th class="pb-4 font-black text-center tracking-widest"
                      >Unitats</th
                    >
                    <th class="pb-4 font-black text-right tracking-widest"
                      >Subtotal</th
                    >
                  </tr>
                </thead>
                <tbody class="text-slate-600">
                  <tr class="border-b border-slate-50">
                    <td class="py-6">
                      <p class="font-black text-slate-900">
                        Desenvolupament Software Fullstack
                      </p>
                      <p class="text-xs text-slate-400 italic">
                        Tarifa Junior: 35€/h (4 desenvolupadors)
                      </p>
                    </td>
                    <td class="py-6 text-center font-bold text-slate-400"
                      >280h</td
                    >
                    <td class="py-6 text-right font-black text-slate-900"
                      >9.800 €</td
                    >
                  </tr>
                  <tr class="border-b border-slate-50">
                    <td class="py-6">
                      <p class="font-black text-slate-900">
                        Allotjament Servidor (IONOS)
                      </p>
                      <p class="text-xs text-slate-400 italic">
                        Hosting microserveis i bases de dades
                      </p>
                    </td>
                    <td class="py-6 text-center font-bold text-slate-400"
                      >4 mesos</td
                    >
                    <td class="py-6 text-right font-black text-slate-900"
                      >48 €</td
                    >
                  </tr>
                  <tr>
                    <td class="py-6">
                      <p class="font-black text-slate-900">
                        Llicències i Eines
                      </p>
                      <p class="text-xs text-slate-400 italic">
                        Android Studio, IntelliJ, Figma Free
                      </p>
                    </td>
                    <td class="py-6 text-center font-bold text-slate-400">—</td>
                    <td
                      class="py-6 text-right font-black text-[#F9C18A] uppercase text-[10px] tracking-widest"
                      >Gratuït</td
                    >
                  </tr>
                </tbody>
              </table>
            </div>

            <div
              class="bg-slate-50/50 p-8 flex justify-between items-center border-t border-slate-100"
            >
              <span
                class="text-slate-400 font-black uppercase text-xs tracking-widest"
                >Valor Total Acumulat</span
              >
              <span class="text-4xl font-black text-slate-900 tracking-tighter"
                >9.848,00 €</span
              >
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div
            class="bg-[#A7D6E9] rounded-[2.5rem] p-8 text-white shadow-2xl shadow-sky-100 relative overflow-hidden"
          >
            <div
              class="absolute -top-10 -right-10 w-32 h-32 bg-white/10 rounded-full blur-3xl"
            >
            </div>
            <h3
              class="text-xl font-black mb-6 flex items-center gap-2 italic uppercase tracking-tighter"
            >
              <span>🚀</span> Prototip Final
            </h3>

            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <span
                  class="bg-white/20 w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-black"
                  >01</span
                >
                <div>
                  <p class="font-black text-sm uppercase tracking-tight">
                    Hores de desenvolupament addicionals
                  </p>
                  <p class="text-[11px] opacity-80 italic">
                    50h polint detalls
                  </p>
                  <p class="text-sm font-black mt-1 text-white">1.750 €</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="bg-white/20 w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-black"
                  >02</span
                >
                <div>
                  <p class="font-black text-sm uppercase tracking-tight">
                    Auditoria Seguretat
                  </p>
                  <p class="text-[11px] opacity-80 italic">Consultoria RGPD</p>
                  <p class="text-sm font-black mt-1 text-white">500 €</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="bg-white/20 w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-black"
                  >03</span
                >
                <div>
                  <p class="font-black text-sm uppercase tracking-tight">
                    Llançament Store
                  </p>
                  <p class="text-[11px] opacity-80 italic">Taxa Google Play</p>
                  <p class="text-sm font-black mt-1 text-white">23 €</p>
                </div>
              </li>
            </ul>

            <div class="mt-10 pt-6 border-t border-white/20 text-center">
              <p
                class="text-[9px] uppercase font-black opacity-60 mb-1 tracking-[0.2em]"
              >
                Manteniment anual
              </p>
              <p class="text-xl font-black italic">~300 €/any</p>
            </div>
          </div>

          <div
            class="bg-white p-8 rounded-[2.5rem] border-4 border-[#F9C18A] shadow-2xl shadow-orange-100 flex flex-col items-center text-center transition-transform hover:scale-[1.02] duration-300"
          >
            <p
              class="text-[10px] font-black uppercase text-[#E69B55] tracking-[0.3em] mb-2"
            >
              Inversió Total
            </p>
            <p
              class="text-5xl font-black text-slate-900 tracking-tighter italic"
            >
              12.421€
            </p>
            <p
              class="text-[11px] text-slate-400 mt-4 leading-relaxed font-medium"
            >
              Inclou el valor del desenvolupament actual i el pressupost per a
              producció.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
